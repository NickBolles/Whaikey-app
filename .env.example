# Copy to .env.local for local development. Do NOT commit real secrets.

# --- Database ---------------------------------------------------------------
# Postgres everywhere. Local dev / tests use PGlite (an in-process WASM
# Postgres) — no server, no network. Production uses hosted Postgres (Supabase).
#
# Local (default if unset): a PGlite data directory.
DATABASE_URL="file:./data/whaikey"
# Production: your Supabase Postgres connection string. Use the connection
# POOLER URL (port 6543) for serverless — the driver disables prepared
# statements so it works with pgbouncer transaction mode.
# DATABASE_URL="postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# --- Auth (Better Auth, social login only) ----------------------------------
# The app's public base URL. Locally this is http://localhost:3000; in
# production set it to your deployed URL (e.g. https://whaikey.vercel.app).
BETTER_AUTH_URL="http://localhost:3000"
# A real random secret in production: `openssl rand -base64 32`.
BETTER_AUTH_SECRET="dev-only-secret-change-me"

# Google OAuth (create at https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (optional, can wait).
# APPLE_CLIENT_ID=""
# APPLE_CLIENT_SECRET=""

# --- AI (Anthropic Claude) --------------------------------------------------
ANTHROPIC_API_KEY=""
# Optional model overrides.
# WHAIKEY_CHAT_MODEL="claude-sonnet-5"
# WHAIKEY_FAST_MODEL="claude-haiku-4-5-20251001"
