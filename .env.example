# Copy to .env.local for local development. Do NOT commit real secrets.

# --- Database ---------------------------------------------------------------
# Local dev / tests use a file-based SQLite DB via better-sqlite3.
# Production (Vercel) uses a hosted libSQL/Turso DB via @libsql/client.
#
# Local (default if unset): a local SQLite file.
DATABASE_URL="file:./data/whaikey.db"
# Production: your Turso database URL + auth token.
# DATABASE_URL="libsql://<your-db>-<org>.turso.io"
# DATABASE_AUTH_TOKEN="<turso-auth-token>"

# --- Auth (Better Auth, social login only) ----------------------------------
# The app's public base URL. Locally this is http://localhost:3000; in
# production set it to your deployed URL (e.g. https://whaikey.vercel.app).
BETTER_AUTH_URL="http://localhost:3000"
# A real random secret in production: `openssl rand -base64 32`.
BETTER_AUTH_SECRET="dev-only-secret-change-me"

# Google OAuth (create at https://console.cloud.google.com/apis/credentials).
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple OAuth (optional, can wait).
# APPLE_CLIENT_ID=""
# APPLE_CLIENT_SECRET=""

# --- AI (Anthropic Claude) --------------------------------------------------
ANTHROPIC_API_KEY=""
# Optional model overrides.
# WHAIKEY_CHAT_MODEL="claude-sonnet-5"
# WHAIKEY_FAST_MODEL="claude-haiku-4-5-20251001"
